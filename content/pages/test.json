{
  "title": "CMS Test Page",
  "content": [
    {
      "type": "heading",
      "text": "CMS Component Page Demo",
      "size": "4xl",
      "as": "h1"
    },
    {
      "type": "text",
      "size": "lg",
      "content": "This page demonstrates the power of our sveltiacms-backed nested component renderer."
    },
    {
      "type": "stack",
      "direction": "vertical",
      "gap": "6",
      "children": [
        {
          "type": "heading",
          "text": "1. Nested Card & Leaves",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "card",
          "children": [
            {
              "type": "checkbox",
              "colorPalette": "blue",
              "label": "I agree to the Cabin Terms & Conditions",
              "checked": true
            },
            {
              "type": "button",
              "text": "Book Cabin Now",
              "variant": "solid",
              "colorPalette": "green",
              "size": "md"
            }
          ],
          "title": "Mountain Cabin Adventure",
          "description": "Experience nature in its purest form.",
          "body": "Located high in the Cascades, our cozy cabin provides a warm fire and majestic views.",
          "image": "https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=800&q=80",
          "imagePosition": "top",
          "footer": ""
        },
        {
          "type": "heading",
          "text": "2. Collapsible Container",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "collapsible",
          "children": [
            {
              "type": "alert",
              "variant": "subtle",
              "title": "Limited Spots",
              "description": "Cabins are filling up fast for the winter season!",
              "status": "warning"
            }
          ],
          "trigger": "Click to expand details",
          "showIndicator": true,
          "indicatorPlacement": "end",
          "open": false,
          "content": "Content"
        },
        {
          "type": "heading",
          "text": "3. Interactive Combobox",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "combobox",
          "label": "Choose Your Favorite Framework",
          "items": [
            {
              "label": "HonoX",
              "value": "hono"
            },
            {
              "label": "React",
              "value": "react"
            },
            {
              "label": "Svelte",
              "value": "svelte"
            },
            {
              "label": "Vue",
              "value": "vue"
            }
          ],
          "placeholder": "Select a framework..."
        },
        {
          "type": "heading",
          "text": "4. Modals & Overlays",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "4",
          "children": [
            {
              "type": "dialog",
              "title": "Terms of Service",
              "description": "Please read our terms before proceeding.",
              "body": "",
              "footer": "",
              "trigger": [
                {
                  "type": "button",
                  "text": "View Terms (Dialog)",
                  "variant": "outline"
                }
              ],
              "cancel": "",
              "confirm": "",
              "confirmText": "Accept",
              "cancelText": "Decline",
              "role": "dialog"
            },
            {
              "type": "drawer",
              "title": "Feedback Panel",
              "description": "We would love to hear from you.",
              "body": "",
              "footer": "",
              "trigger": [
                {
                  "type": "button",
                  "text": "Give Feedback (Drawer)",
                  "variant": "outline"
                }
              ],
              "cancel": "",
              "confirm": "",
              "confirmText": "Submit",
              "cancelText": "Cancel"
            }
          ]
        }
      ]
    },
    {
      "type": "drawer",
      "title": "TitleDrawer",
      "description": "Description",
      "body": "Body",
      "trigger": [
        {
          "type": "button",
          "variant": "solid",
          "text": "TriggerDrawer"
        }
      ],
      "confirmText": "",
      "cancelText": "",
      "footer": "Footer",
      "closable": true,
      "interactive": true,
      "cancel": "",
      "confirm": ""
    },
    {
      "type": "hoverCard",
      "children": [
        {
          "type": "alert",
          "title": "alert",
          "description": "desc",
          "variant": "subtle",
          "status": "info"
        }
      ],
      "title": "ttl",
      "description": "desc",
      "triggerText": "Hover me",
      "showArrow": true
    },
    {
      "type": "field",
      "children": [],
      "disabled": false,
      "label": "label",
      "helperText": "helper",
      "errorText": "error",
      "defaultValue": "123",
      "invalid": false,
      "required": true,
      "readOnly": false
    },
    {
      "type": "radioGroup",
      "label": "label",
      "defaultValue": "",
      "items": [
        {
          "label": "label1",
          "value": "value1",
          "disabled": false
        },
        {
          "label": "label2",
          "value": "value2",
          "disabled": false
        }
      ],
      "colorPalette": "",
      "size": "md"
    },
    {
      "type": "radioCardGroup",
      "label": "Plan",
      "defaultValue": "pro",
      "variant": "surface",
      "colorPalette": "blue",
      "items": [
        {
          "label": "Hobby",
          "value": "hobby",
          "disabled": false
        },
        {
          "label": "Pro",
          "value": "pro",
          "disabled": false
        },
        {
          "label": "Enterprise",
          "value": "enterprise",
          "disabled": true
        }
      ]
    },
    {
      "type": "editable",
      "label": "Project name",
      "defaultValue": "Mountain Cabin Adventure",
      "size": "md",
      "activationMode": "focus",
      "submitMode": "both"
    },
    {
      "type": "heading",
      "text": "5. New Component Bindings",
      "size": "2xl",
      "as": "h2"
    },
    {
      "type": "breadcrumb",
      "items": [
        { "label": "Home", "href": "/" },
        { "label": "Docs", "href": "/docs" },
        { "label": "Test Page" }
      ],
      "variant": "underline",
      "size": "md"
    },
    {
      "type": "datePicker",
      "label": "Check-in Date",
      "selectionMode": "single",
      "placeholder": "YYYY-MM-DD",
      "colorPalette": "blue"
    },
    {
      "type": "tagsInput",
      "label": "Amenities",
      "defaultValue": ["WiFi", "Fireplace", "Hot Tub"]
    },
    {
      "type": "stack",
      "direction": "horizontal",
      "gap": "4",
      "children": [
        {
          "type": "loader",
          "text": "Checking availability..."
        },
        {
          "type": "spinner",
          "size": "lg",
          "label": "Loading"
        }
      ]
    },
    {
      "type": "table",
      "columns": [
        { "header": "Room", "key": "room" },
        { "header": "Price", "key": "price", "align": "end" }
      ],
      "rows": "[{\"room\": \"Cabin Loft\", \"price\": \"$180/night\"}, {\"room\": \"Cabin Suite\", \"price\": \"$240/night\"}]",
      "variant": "plain",
      "striped": true
    },
    {
      "type": "tooltip",
      "content": "Free cancellation up to 24 hours before check-in.",
      "triggerText": "Cancellation Policy",
      "placement": "top",
      "showArrow": true
    },
    {
      "type": "absoluteCenter",
      "axis": "both",
      "children": [
        {
          "type": "badge",
          "text": "Centered Badge",
          "colorPalette": "purple",
          "variant": "solid"
        }
      ]
    },
    {
      "type": "splitter",
      "orientation": "horizontal",
      "panels": [
        {
          "id": "left",
          "content": [{ "type": "text", "content": "Left panel" }]
        },
        {
          "id": "right",
          "content": [{ "type": "text", "content": "Right panel" }]
        }
      ]
    }
  ]
}
